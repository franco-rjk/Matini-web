@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- HERO SECTION -->
<section class="hero" id="inicio">
    <div class="hero-bg-text">RIVER</div>
    <div class="hero-stripe hero-stripe-1"></div>
    <div class="hero-stripe hero-stripe-2"></div>

    <div class="hero-content">
        <div class="hero-badge-top animate-fade-up delay-1">
            <span class="live-dot"></span> STREAMER AFILIADO KICK
        </div>
        <h1 class="hero-title animate-fade-up delay-2">
            <span class="title-name">MATINI</span>
            <span class="title-sub">Creador de contenido de fútbol</span>
        </h1>
        <p class="hero-desc animate-fade-up delay-3">
            ⚽ Fútbol, análisis, humor y pasión riverplatense.<br>
            Seguime en todas las plataformas y sumate a la banda.
        </p>
        <div class="hero-ctas animate-fade-up delay-4">
            <a href="https://kick.com/matiniii" target="_blank" class="btn-primary">
                <span class="btn-icon">▶</span> VER EN VIVO
            </a>
            <a href="#redes" class="btn-secondary">SEGUIRME</a>
        </div>

        <div class="hero-stats animate-fade-up delay-5">
            <div class="stat">
                <span class="stat-num" data-target="9708">0</span>
                <span class="stat-label">Seguidores IG</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
                <span class="stat-num" data-target="587">0</span>
                <span class="stat-label">Publicaciones</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
                <span class="stat-num" data-target="2138">0</span>
                <span class="stat-label">Seguidos</span>
            </div>
        </div>
    </div>

    <div class="hero-ball">⚽</div>
    <div class="scroll-indicator">
        <span>SCROLL</span>
        <div class="scroll-line"></div>
    </div>
</section>

<!-- SOBRE MÍ -->
<section class="section sobre-mi" id="sobre-mi">
    <div class="section-label">// SOBRE MÍ</div>
    <div class="sobre-grid">
        <div class="sobre-text reveal">
            <h2 class="section-title">LA PASIÓN DE<br><span class="accent">RIVER</span> HECHA<br>CONTENIDO</h2>
            <p>Soy <strong>Mateo Tamini</strong>, creador de contenido de fútbol con una chispa de humor. Streamer Afiliado en Kick, subo análisis, reacciones y entretenimiento futbolero.</p>
            <p>El fútbol no es solo un deporte, es una forma de vida. Y con River en el corazón, cada stream es una fiesta.</p>
            <div class="tags">
                <span class="tag">⚽ Fútbol</span>
                <span class="tag">🎮 Streaming</span>
                <span class="tag">😂 Humor</span>
                <span class="tag">🏆 River Plate</span>
            </div>
        </div>
        <div class="sobre-card reveal delay-2">
            <div class="card-inner">
                <div class="card-icon">🎙️</div>
                <div class="card-platform">STREAMER AFILIADO</div>
                <div class="card-name">@@mateotaminiii</div>
                <div class="card-divider"></div>
                <div class="card-info">
                    <div>📍 Argentina</div>
                    <div>📩 mateotaminicontacto@@gmail.com</div>
                </div>
                <div class="card-river">
                    <span class="river-band"></span>
                    <span>¡Vamos River!</span>
                    <span class="river-band"></span>
                </div>
            </div>
        </div>
    </div>
</section>

