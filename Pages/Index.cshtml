        </div>

        <div class="platform-card youtube reveal delay-2">
            <div class="platform-glow yt-glow"></div>
            <div class="platform-icon">▶️</div>
            <div class="platform-name">YOUTUBE</div>
            <div class="platform-handle">@@mateotamini</div>
